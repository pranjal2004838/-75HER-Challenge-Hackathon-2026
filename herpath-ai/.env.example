# HERPath AI Environment Configuration
# Copy this file to .env and fill in your actual credentials
# DO NOT COMMIT .env with real secrets!

# Firebase Configuration
# Get these from firebase_config.py or Firebase Console
FIREBASE_CREDENTIALS_JSON='{"type":"service_account","project_id":"YOUR_PROJECT_ID","private_key":"YOUR_PRIVATE_KEY",...}'
FIREBASE_DATABASE_URL='https://your-project.firebasedatabase.app'

# Google Gemini API Key
# Get from https://ai.google.dev/
GEMINI_API_KEY='YOUR_GEMINI_API_KEY_HERE'

# Streamlit Configuration (Optional)
# For Streamlit Secrets, use .streamlit/secrets.toml instead
# STREAMLIT_CLIENT_LOGGER_LEVEL=info
